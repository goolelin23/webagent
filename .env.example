# ============================================
# 智能Web自动化Agent系统 — 环境变量配置
# ============================================
# 只需配置你使用的模型提供商的 API Key 即可

# ── LLM 模型选择 ──
# 可选: openai / anthropic / gemini / qwen
LLM_PROVIDER=anthropic
# 模型名称（留空则使用提供商默认值）
# OpenAI 默认: gpt-4o | Anthropic 默认: claude-sonnet-4-20250514
# Gemini 默认: gemini-2.0-flash | 千问 默认: qwen-max
LLM_MODEL=

# ── API Keys（至少配置一个）──

# OpenAI
# OPENAI_API_KEY=sk-your-openai-key
# OPENAI_API_BASE=                     # 可选, 私有部署时设置

# Anthropic (Claude)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Google (Gemini)
# GOOGLE_API_KEY=your-google-api-key

# 阿里云千问 (Qwen / 通义)
# QWEN_API_KEY=your-dashscope-api-key
# QWEN_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1

# ── LLM 通用参数 ──
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096

# ── Browser Use Cloud（可选，用于云端浏览器）──
# BROWSER_USE_API_KEY=your-browser-use-api-key

# ── 浏览器配置 ──
BROWSER_HEADLESS=false
BROWSER_VIEWPORT_WIDTH=1280
BROWSER_VIEWPORT_HEIGHT=800

# ── 安全配置 ──
SAFETY_LEVEL=medium
# low    : 仅拦截 CRITICAL 操作
# medium : 拦截 HIGH + CRITICAL 操作（推荐）
# high   : 拦截 MEDIUM 及以上操作

# ── 管线配置 ──
MAX_RETRIES=3
RETRY_DELAY=2.0
PAGE_LOAD_TIMEOUT=30000
ELEMENT_TIMEOUT=10000

# ── 日志配置 ──
LOG_LEVEL=INFO
LOG_FILE=logs/webagent.log

# ── 知识库存储路径 ──
KNOWLEDGE_BASE_DIR=knowledge_base
